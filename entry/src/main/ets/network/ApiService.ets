/**
 * API жңҚеҠЎеұӮ
 * е°ҒиЈ…жүҖжңү JMComic API и°ғз”Ё
 * еҜ№еә” Python йЎ№зӣ®дёӯзҡ„ JmApiClient
 *
 * еҹҹеҗҚз®ЎзҗҶеўһејәпјҡ
 * - йӣҶжҲҗ DomainManager е®һзҺ°еҹҹеҗҚж•…йҡңиҪ¬з§»
 * - иҜ·жұӮеӨұиҙҘж—¶иҮӘеҠЁеҲҮжҚўеҹҹеҗҚйҮҚиҜ•
 * - еҗҺеҸ°е®ҡжңҹжҺўжҙ»жҒўеӨҚдёҚеҸҜиҫҫеҹҹеҗҚ
 */
export class ApiService {
  private domainManager: DomainManager;
  private userSession: UserSession = new UserSession();

  constructor() {
    this.domainManager = new DomainManager(DOMAIN_API_LIST, DOMAIN_IMAGE_LIST);
    // еҗҜеҠЁеҗҺеҸ°е®ҡжңҹеӨҚжҺў
    this.domainManager.startPeriodicProbe();
  }

  // в”Җв”Җв”Җ еҹҹеҗҚз®ЎзҗҶ в”Җв”Җв”Җ

  /** иҺ·еҸ–еҹҹеҗҚз®ЎзҗҶеҷЁпјҲдҫӣеӨ–йғЁи°ғиҜ•пјү */
  getDomainManager(): DomainManager {
    return this.domainManager;
  }

  /** жү§иЎҢеҹҹеҗҚжҺўжҙ»пјҢйҖҡеёёеңЁеә”з”ЁеҗҜеҠЁж—¶и°ғз”Ё */
  async probeDomains(): Promise<void> {
    await this.domainManager.probeAllDomains();
  }

  /** жүӢеҠЁеҲҮжҚўеҹҹеҗҚпјҲиҺ·еҸ–дёӢдёҖдёӘжңҖдҪіеҹҹеҗҚпјү */
  refreshDomains(): void {
    // DomainManager еҶ…йғЁе·ІиҮӘеҠЁз®ЎзҗҶжңҖдҪіеҹҹеҗҚйҖүжӢ©
    // жӯӨж–№жі•дҝқз•ҷдҫӣеӨ–йғЁжүӢеҠЁи§ҰеҸ‘жҺўжҙ»
    console.info('[ApiService] refreshDomains: еҪ“еүҚжңҖдҪі API=' +
      this.domainManager.getBestApiDomain() +
      ' еӣҫзүҮ=' + this.domainManager.getBestImageDomain());
  }

  getImageDomain(): string {
    return this.domainManager.getBestImageDomain();
  }

  /** иҺ·еҸ–еҪ“еүҚжңҖдҪіеӣҫзүҮ CDN еҹәзЎҖ URL (еҹҹеҗҚе·Іеҗ« cdn-msp. еүҚзјҖ) */
  private getImageBaseUrl(): string {
    return PROT + this.domainManager.getBestImageDomain();
  }

  /**
   * жһ„е»әе°Ғйқўеӣҫ URL
   * @param albumId  album id
   * @param size     е°әеҜёеҗҺзјҖ: еҲ—иЎЁйЎө "_3x4", иҜҰжғ…йЎө ""
   */
  buildCoverUrl(albumId: string | number, size: string = '_3x4'): string {
    return `${this.getImageBaseUrl()}/media/albums/${albumId}${size}.jpg`;
  }

  // в”Җв”Җв”Җ ж ёеҝғиҜ·жұӮж–№жі•пјҲеёҰеҹҹеҗҚж•…йҡңиҪ¬з§»пјү в”Җв”Җв”Җ

  /**
   * еёҰеҹҹеҗҚж•…йҡңиҪ¬з§»зҡ„ API иҜ·жұӮ
   *
   * ж ёеҝғйҖ»иҫ‘пјҡ
   * 1. д»Һ DomainManager иҺ·еҸ–жңҖдҪіеҹҹеҗҚ
   * 2. жһ„е»әе®Ңж•ҙ URL е№¶еҸ‘иө·иҜ·жұӮ
   * 3. жҲҗеҠҹ вҶ’ жҠҘе‘ҠжҲҗеҠҹгҖҒиҝ”еӣһз»“жһң
   * 4. еӨұиҙҘ вҶ’ жҠҘе‘ҠеӨұиҙҘгҖҒиҺ·еҸ–дёӢдёҖдёӘжңҖдҪіеҹҹеҗҚгҖҒйҮҚиҜ•
   *
   * иҝҷдёӘж–№жі•жҳҜжүҖжңү API и°ғз”Ёзҡ„з»ҹдёҖе…ҘеҸЈпјҢеҜ№еә” Java RetryAndDomainRedirectInterceptor
   *
   * @param path      API и·Ҝеҫ„ (еҰӮ '/search')
   * @param method    GET жҲ– POST
   * @param body      иҜ·жұӮдҪ“ (POST ж—¶дҪҝз”ЁпјҢform-urlencoded еӯ—з¬ҰдёІ)
   * @param headers   иҜ·жұӮеӨҙ
   * @param maxDomainSwitches жңҖеӨ§еҹҹеҗҚеҲҮжҚўж¬Ўж•°пјҲй»ҳи®Өе°қиҜ•жүҖжңүеҹҹеҗҚпјү
   * @returns е“Қеә” body еӯ—з¬ҰдёІ
   */
  private async requestApi(
    path: string,
    method: 'GET' | 'POST',
    body: string | null,
    headers: Record<string, string>,
    maxDomainSwitches: number = DOMAIN_API_LIST.length
  ): Promise<string> {
    let lastErr: Error | null = null;
    let triedDomains: Set<string> = new Set();

    for (let attempt = 0; attempt < maxDomainSwitches; attempt++) {
      let domain = this.domainManager.getBestApiDomain();

      // и·іиҝҮе·Іе°қиҜ•иҝҮзҡ„еҹҹеҗҚпјҲйҒҝе…ҚеҫӘзҺҜдҪҝз”ЁеҗҢдёҖеҹҹеҗҚпјү
      if (triedDomains.has(domain)) {
        continue;
      }
      triedDomains.add(domain);

      let url = `${PROT}${domain}${path}`;

      try {
        let result: string;
        if (method === 'GET') {
          // GET иҜ·жұӮдҪҝз”ЁеҚ•ж¬Ўе°қиҜ•пјҲеҹҹеҗҚеҲҮжҚўеңЁеӨ–еұӮеӨ„зҗҶпјү
          result = await HttpClient.get(url, headers, 1);
        } else {
          // POST иҜ·жұӮдҪҝз”ЁеҚ•ж¬Ўе°қиҜ•
          result = await HttpClient.post(url, body || '', headers, 1);
        }
        // иҜ·жұӮжҲҗеҠҹпјҢжҠҘе‘ҠеҹҹеҗҚжҲҗеҠҹ
        this.domainManager.reportApiSuccess(domain);
        console.info(`[ApiService] вң“ ${domain}${path}`);
        return result;
      } catch (err) {
        lastErr = err as Error;
        // иҜ·жұӮеӨұиҙҘпјҢжҠҘе‘ҠеҹҹеҗҚеӨұиҙҘ
        this.domainManager.reportApiFailure(domain);
        console.warn(`[ApiService] вң— ${domain}${path} (attempt ${attempt + 1}/${maxDomainSwitches}): ${lastErr.message}`);

        if (attempt < maxDomainSwitches - 1) {
          await HttpClient.sleep(500);
        }
      }
    }

    throw lastErr || new Error(`жүҖжңү API еҹҹеҗҚиҜ·жұӮеқҮеӨұиҙҘ: ${path}`);
  }

  // в”Җв”Җв”Җ жҗңзҙў в”Җв”Җв”Җ

  /**
   * жҗңзҙўжј«з”»
   * еҜ№еә” QT: GetSearchReq2 вҖ” GET /search?search_query=xxx&page=N&o=mr
   *
   * @param keyword жҗңзҙўе…ій”®иҜҚ
   * @param page йЎөз Ғ (д»Һ 1 ејҖе§Ӣ)
   * @returns жҗңзҙўз»“жһң
   */
  async search(keyword: string, page: number = 1): Promise<JmApiResponse<SearchResultData>> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let queryParams: Record<string, string> = {};
    queryParams['main_tag'] = '0';
    queryParams['search_query'] = keyword;
    queryParams['page'] = page.toString();
    queryParams['o'] = 'mr';
    queryParams['t'] = 'a';
    let queryString = ApiService.buildFormBody(queryParams);

    let path = `${API_SEARCH}?${queryString}`;

    let respStr = await this.requestApi(path, 'GET', null, headers);
    return await this.decryptResponse<SearchResultData>(respStr, ts);
  }

  /**
   * иҺ·еҸ–йҰ–йЎөжҺЁиҚҗеҲҶзұ»еҲ—иЎЁ
   * еҜ№еә” QT: GetIndexInfoReq2 вҖ” GET /promote?page=0
   *
   * иҝ”еӣһж•°жҚ®з»“жһ„: [{title: "жңҖж–°дёҠдј ", content: [JmAlbumInfo, ...]}, ...]
   */
  async getPromote(page: number = 0): Promise<JmApiResponse<JmPromoteSection[]>> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let path = `/promote?page=${page}`;

    let respStr = await this.requestApi(path, 'GET', null, headers);
    return await this.decryptResponse<JmPromoteSection[]>(respStr, ts);
  }

  /**
   * иҺ·еҸ–еҲҶзұ»еҲ—иЎЁ (йҰ–йЎөжҺЁиҚҗ)
   * еҜ№еә” QT: GetSearchCategoryReq2 вҖ” GET /categories/filter/?c=0&page=N&o=mr
   *
   * @param category еҲҶзұ»ж ҮиҜҶ
   * @param order жҺ’еәҸж–№ејҸ
   * @param page йЎөз Ғ
   */
  async getCategoryList(
    category: string = '0',
    order: string = 'mr',
    page: number = 1
  ): Promise<JmApiResponse<SearchResultData>> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let queryParams: Record<string, string> = {};
    queryParams['page'] = page.toString();
    queryParams['order'] = '';
    queryParams['o'] = order;
    if (category && category !== '0') {
      queryParams['c'] = category;
    }
    let queryString = ApiService.buildFormBody(queryParams);

    let path = `${API_CATEGORIES_FILTER}?${queryString}`;

    let respStr = await this.requestApi(path, 'GET', null, headers);
    return await this.decryptResponse<SearchResultData>(respStr, ts);
  }

  // в”Җв”Җв”Җ Album иҜҰжғ… в”Җв”Җв”Җ

  /**
   * иҺ·еҸ– Album иҜҰжғ…
   * еҜ№еә” QT: GetBookInfoReq2 вҖ” GET /album/?comicName=&id=xxx
   *
   * @param albumId Album ID
   */
  async getAlbumDetail(albumId: number): Promise<JmApiResponse<JmAlbumDetail>> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let queryParams: Record<string, string> = {};
    queryParams['id'] = albumId.toString();
    let queryString = ApiService.buildFormBody(queryParams);

    let path = `${API_ALBUM}?${queryString}`;

    let respStr = await this.requestApi(path, 'GET', null, headers);
    return await this.decryptResponse<JmAlbumDetail>(respStr, ts);
  }

  // в”Җв”Җв”Җ еӣҫзүҮ/з« иҠӮ в”Җв”Җв”Җ

  /**
   * иҺ·еҸ–з« иҠӮзҡ„еӣҫзүҮеҲ—иЎЁ
   * еҜ№еә” QT: GetBookEpsInfoReq2 вҖ” GET /chapter/?comicName=&skip=&id=xxx
   * еҜ№еә” QT: GetBookEpsScrambleReq2 вҖ” GET /chapter_view_template/?id=xxx&mode=vertical&page=0&app_img_shunt=NaN
   *
   * жӯЈзЎ®жөҒзЁӢпјҡ
   * 1. GET /chapter?id=xxx вҶ’ иҺ·еҸ–еӣҫзүҮж–Үд»¶еҗҚзӯүе…ғж•°жҚ®
   * 2. GET /chapter_view_template?id=xxx&mode=vertical&page=0&app_img_shunt=NaN вҶ’ д»Һ HTML жҸҗеҸ– scramble_id
   * 3. з”Ё scramble_id + imageDomain жһ„е»әжӯЈзЎ®зҡ„еӣҫзүҮ URL
   *
   * @param photoId photo_id
   * @param scrambleId scramble_idпјҲд»Һ album detail йў„еҸ–пјҢдҪңдёә fallbackпјү
   */
  async getChapterPictures(photoId: string, scrambleId: number): Promise<PictureData> {
    // в”Җв”Җ жӯҘйӘӨ 1: GET /chapter иҺ·еҸ–еӣҫзүҮе…ғж•°жҚ® в”Җв”Җ
    // еҜ№еә” QT: GetBookEpsInfoReq2 вҖ” GET /chapter/?comicName=&skip=&id={epsId}
    let ts1 = CryptoUtils.timestamp();
    let headers1 = await this.buildTokenHeaders(ts1);

    let chapterParams: Record<string, string> = {};
    chapterParams['comicName'] = '';
    chapterParams['skip'] = '';
    chapterParams['id'] = photoId;
    let chapterQuery = ApiService.buildFormBody(chapterParams);
    let chapterPath = `${API_CHAPTER}/?${chapterQuery}`;

    let chapterResp = await this.requestApi(chapterPath, 'GET', null, headers1);
    // /chapter и§ЈеҜҶеҗҺжҳҜжүҒе№із»“жһ„: {id, name, series_id, series, tags, images: ["f1.webp", ...]}
    // дёҚиғҪз”Ё PictureData жіӣеһӢпјҢзӣҙжҺҘжҢү Record и§Јжһҗ
    let apiResp = await this.decryptResponse<Record<string, Object>>(chapterResp, ts1);

    if (apiResp.code !== 200) {
      throw new Error(`иҺ·еҸ–з« иҠӮеӨұиҙҘ: code=${apiResp.code}, msg=${apiResp.message}`);
    }
    let raw = apiResp.data;
    if (!raw) {
      throw new Error('з« иҠӮж•°жҚ®дёәз©әпјҢphotoId=' + photoId);
    }

    // в”Җв”Җ жӯҘйӘӨ 2: GET /chapter_view_template иҺ·еҸ– scramble_id в”Җв”Җ
    // иҜҘжҺҘеҸЈдҪҝз”Ё APP_TOKEN_SECRET_2 еҜҶй’Ҙ
    let ts2 = CryptoUtils.timestamp();
    let headers2 = await this.buildTokenHeaders(ts2, APP_TOKEN_SECRET_2);

    let fetchedScrambleId: number = scrambleId;
    try {
      let scrambleParams: Record<string, string> = {};
      scrambleParams['id'] = photoId;
      scrambleParams['mode'] = 'vertical';
      scrambleParams['page'] = '0';
      scrambleParams['app_img_shunt'] = 'NaN';
      let scrambleQuery = ApiService.buildFormBody(scrambleParams);
      let scramblePath = `${API_SCRAMBLE}?${scrambleQuery}`;

      let scrambleHtml = await this.requestApi(scramblePath, 'GET', null, headers2);
      // д»Һ HTML дёӯжҸҗеҸ– var scramble_id = 220980;
      let regex = /var scramble_id = (\d+);/;
      let match = scrambleHtml.match(regex);
      if (match && match[1]) {
        fetchedScrambleId = parseInt(match[1]);
        console.info(`[ApiService] fetched scramble_id=${fetchedScrambleId} for photo=${photoId}`);
      } else {
        console.warn(`[ApiService] scramble_id not found in HTML, using fallback=${scrambleId}`);
      }
    } catch (err) {
      console.error(`[ApiService] fetch scramble_id failed: ${JSON.stringify(err)}, using fallback=${scrambleId}`);
    }

    // в”Җв”Җ жӯҘйӘӨ 3: жһ„е»әжӯЈзЎ®зҡ„еӣҫзүҮ URL в”Җв”Җ
    // images жҳҜж–Үд»¶еҗҚеӯ—з¬ҰдёІж•°з»„: ["00001.webp", "00002.webp", ...]
    let imageBaseUrl = this.getImageBaseUrl();
    let rawImages: string[] = raw['images'] as string[] || [];
    let photoName: string = (raw['name'] as string) || '';

    let jmImages: JmImageInfo[] = [];
    for (let filename of rawImages) {
      let imgUrl = `${imageBaseUrl}/media/photos/${photoId}/${filename}`;
      jmImages.push({
        img_name: filename,
        img_url: imgUrl,
        download_url: imgUrl,
      });
    }

    // е°ҒиЈ…дёә PictureData иҝ”еӣһ
    return {
      pictures: {
        id: parseInt(photoId) || 0,
        photo_id: photoId,
        name: photoName,
        images: jmImages,
        scramble_id: fetchedScrambleId,
      }
    };
  }

  // в”Җв”Җв”Җ ж”¶и—Ҹзі»з»ҹ в”Җв”Җв”Җ

  /**
   * иҺ·еҸ–ж”¶и—ҸеӨ№еҲҶйЎөж•°жҚ®
   * еҜ№еә” Java: JmApiClient.getFavorites(FavoriteQuery)
   * еҜ№еә” Python: JmApiClient.favorite_folder()
   *
   * API: GET /favorite?page=N&folder_id=N (йңҖиҰҒзҷ»еҪ• cookies)
   *
   * @param page йЎөз ҒпјҲд»Һ1ејҖе§Ӣпјү
   * @param folderId ж”¶и—ҸеӨ№IDпјҢ'0'иЎЁзӨәе…ЁйғЁ
   * @returns ж”¶и—ҸеӨ№дёҖйЎөж•°жҚ®
   */
  async getFavorites(page: number = 1, folderId: string = '0'): Promise<JmApiResponse<FavoritePageData>> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let path = `${API_FAVORITE}?page=${page}&folder_id=${folderId}`;
    let respStr = await this.requestApi(path, 'GET', null, headers);
    return await this.decryptResponse<FavoritePageData>(respStr, ts);
  }

  /**
   * еҲҮжҚўж”¶и—ҸзҠ¶жҖҒпјҲж”¶и—Ҹ/еҸ–ж¶Ҳж”¶и—Ҹпјү
   * жңҚеҠЎз«ҜиҮӘеҠЁеҲӨж–ӯпјҡе·Іж”¶и—ҸеҲҷеҸ–ж¶ҲпјҢжңӘж”¶и—ҸеҲҷж·»еҠ 
   *
   * API: POST /favorite  body: aid=albumId
   * еҜ№еә” Java: JmApiClient.toggleAlbumFavorite()
   * еҜ№еә” Python: JmApiClient.add_favorite_album()
   *
   * @param albumId жң¬еӯҗID
   * @returns ж“ҚдҪңз»“жһң {status: "ok", msg: "..."}
   */
  async toggleFavorite(albumId: string): Promise<FavoriteActionResult> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let bodyParams: Record<string, string> = {};
    bodyParams['aid'] = albumId;
    let body = ApiService.buildFormBody(bodyParams);

    let respStr = await this.requestApi(API_FAVORITE, 'POST', body, headers);
    let resp = await this.decryptResponse<FavoriteActionResult>(respStr, ts);
    if (resp.code !== 200) {
      throw new Error(resp.message || 'ж”¶и—Ҹж“ҚдҪңеӨұиҙҘ');
    }
    return resp.data;
  }

  /**
   * з®ЎзҗҶж”¶и—ҸеӨ№пјҲж–°е»ә/йҮҚе‘ҪеҗҚ/з§»еҠЁ/еҲ йҷӨж–Үд»¶еӨ№пјү
   *
   * API: POST /favorite_folder
   * еҜ№еә” Java: JmApiClient.manageFavoriteFolder()
   *
   * @param type       ж“ҚдҪңзұ»еһӢпјҡadd/edit/move/del
   * @param folderId   ж–Үд»¶еӨ№ID
   * @param folderName ж–Үд»¶еӨ№еҗҚз§°пјҲadd/editж—¶йңҖиҰҒпјү
   * @param albumId    жң¬еӯҗIDпјҲmoveж—¶йңҖиҰҒпјү
   * @returns ж“ҚдҪңз»“жһң
   */
  async manageFavoriteFolder(
    type: FavoriteFolderType,
    folderId: string = '',
    folderName: string = '',
    albumId: string = ''
  ): Promise<FavoriteActionResult> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let params: Record<string, string> = {};
    params['type'] = type;
    if (folderId) {
      params['folder_id'] = folderId;
    }
    if (folderName) {
      params['folder_name'] = folderName;
    }
    if (albumId) {
      params['aid'] = albumId;
    }

    let body = ApiService.buildFormBody(params);
    let respStr = await this.requestApi(API_FAVORITE_FOLDER, 'POST', body, headers);
    let resp = await this.decryptResponse<FavoriteActionResult>(respStr, ts);
    if (resp.code !== 200) {
      throw new Error(resp.message || 'ж”¶и—ҸеӨ№ж“ҚдҪңеӨұиҙҘ');
    }
    return resp.data;
  }

  // в”Җв”Җв”Җ зҷ»еҪ•зі»з»ҹ в”Җв”Җв”Җ

  /**
   * з”ЁжҲ·зҷ»еҪ•
   * еҜ№еә” Python: JmApiClient.login() вҖ” App API зүҲжң¬
   * еҜ№еә” QT: LoginReq2 вҖ” POST /login {username, password}
   *
   * API: POST /login
   * body: username=xxx&password=xxx
   *
   * иҝ”еӣһз”ЁжҲ·дҝЎжҒҜпјҢеҗҢж—¶е°Ҷ session token еӯҳе…ҘеҶ…йғЁ session
   *
   * @param username з”ЁжҲ·еҗҚ
   * @param password еҜҶз Ғ
   * @returns з”ЁжҲ·дҝЎжҒҜ
   */
  async login(username: string, password: string): Promise<UserSession> {
    let ts = CryptoUtils.timestamp();
    let headers = await this.buildTokenHeaders(ts);

    let bodyParams: Record<string, string> = {};
    bodyParams['username'] = username;
    bodyParams['password'] = password;
    let body = ApiService.buildFormBody(bodyParams);

    let respStr = await this.requestApi(API_LOGIN, 'POST', body, headers);

    // login е“Қеә”д№ҹжҳҜеҠ еҜҶзҡ„пјҲеҸҢеұӮз»“жһ„пјүпјҢйңҖиҰҒи§ЈеҜҶ
    let resp = await this.decryptResponse<JmUserData>(respStr, ts);
    if (resp.code !== 200) {
      throw new Error(resp.message || 'зҷ»еҪ•еӨұиҙҘ');
    }

    this.userSession = UserSession.fromApiData(resp.data);
    console.info(`[ApiService] login success: uid=${this.userSession.uid}, username=${this.userSession.username}`);
    return this.userSession;
  }

  /**
   * жЈҖжҹҘз”ЁжҲ·жҳҜеҗҰе·Ізҷ»еҪ•
   */
  isLoggedIn(): boolean {
    return this.userSession.isLoggedIn;
  }

  /**
   * иҺ·еҸ–еҪ“еүҚз”ЁжҲ·дјҡиҜқ
   */
  getUserSession(): UserSession {
    return this.userSession;
  }

  /**
   * йҖҖеҮәзҷ»еҪ•
   */
  logout(): void {
    this.userSession.logout();
    console.info('[ApiService] logout');
  }

  // в”Җв”Җв”Җ иҫ…еҠ©ж–№жі• в”Җв”Җв”Җ

  /**
   * жһ„е»әеёҰ token/tokenparam зҡ„иҜ·жұӮеӨҙ
   * еҜ№еә” QT: ServerReq.GetHeader()
   *
   * token = MD5(timestamp + secret)
   * tokenparam = "timestamp,version"
   *
   * @param ts ж—¶й—ҙжҲіеӯ—з¬ҰдёІ
   * @param secret еҜҶй’ҘпјҢй»ҳи®Ө APP_TOKEN_SECRET
   */
  private async buildTokenHeaders(
    ts: string,
    secret: string = APP_TOKEN_SECRET
  ): Promise<Record<string, string>> {
    let tokenResult = await CryptoUtils.tokenAndTokenparam(ts, secret);
    return {
      'token': tokenResult[0],
      'tokenparam': tokenResult[1],
    };
  }

  /**
   * и§ЈеҜҶ API е“Қеә”
   *
   * е“Қеә”дёәеҸҢеұӮз»“жһ„пјҡ
   * еӨ–еұӮжҳҺж–Ү JSON: {"code": 200, "data": "<base64еҠ еҜҶеӯ—з¬ҰдёІ>", "message": "..."}
   * data еӯ—ж®ө: base64 вҶ’ AES-ECB и§ЈеҜҶ вҶ’ жҳҺж–Ү JSON: {"total": "...", "content": [...]}
   *
   * еҜ№еә” QT: v = json.loads(response); result = ParseData(v.get("data"))
   */
  private async decryptResponse<T>(respStr: string, ts: string): Promise<JmApiResponse<T>> {
    // 1. и§ЈжһҗеӨ–еұӮ JSON
    let outer: JmApiResponse<T>;
    try {
      outer = JSON.parse(respStr) as JmApiResponse<T>;
    } catch (_) {
      // ж•ҙдёӘе“Қеә”дёҚжҳҜ JSONпјҢе°қиҜ•ж•ҙдҪ“и§ЈеҜҶ
      let decrypted = await CryptoUtils.decodeRespData(respStr, ts);
      return JSON.parse(decrypted) as JmApiResponse<T>;
    }

    // 2. жЈҖжҹҘ codeпјҢеҰӮжһңиҜ·жұӮеӨұиҙҘзӣҙжҺҘиҝ”еӣһ
    if (outer.code !== 200) {
      return outer;
    }

    // 3. data еӯ—ж®өжҳҜ base64 еҠ еҜҶеӯ—з¬ҰдёІпјҢйңҖиҰҒи§ЈеҜҶ
    if (typeof outer.data === 'string' && (outer.data as string).length > 0) {
      try {
        let decrypted = await CryptoUtils.decodeRespData(outer.data as string, ts);
        let innerData = JSON.parse(decrypted) as T;
        outer.data = innerData;
      } catch (err) {
        console.error(`[ApiService] decryptResponse data field error: ${JSON.stringify(err)}`);
        console.error(`[ApiService] raw data field: ${(outer.data as string).substring(0, 100)}`);
        throw err as Error;
      }
    }

    return outer;
  }

  /**
   * жһ„е»ә form-urlencoded body
   */
  private static buildFormBody(params: Record<string, string>): string {
    let parts: string[] = [];
    let keys = Object.keys(params);
    for (let i = 0; i < keys.length; i++) {
      let k = keys[i];
      parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(params[k]));
    }
    return parts.join('&');
  }

  /**
   * жһ„е»әеӣҫзүҮ URL
   * дҪҝз”Ё DomainManager иҺ·еҸ–жңҖдҪіеӣҫзүҮеҹҹеҗҚ
   */
  getImageUrl(imgName: string, photoId: string | number): string {
    let baseUrl = this.getImageBaseUrl();
    return `${baseUrl}/media/photos/${photoId}/${imgName}`;
  }

  /**
   * иҺ·еҸ–еӣҫзүҮ URLпјҲеёҰеҗҺзјҖжҺўжөӢпјү
   */
  getImageUrlWithSuffix(imgName: string, photoId: string | number, suffix: string = '.jpg'): string {
    let baseUrl = this.getImageBaseUrl();
    return `${baseUrl}/media/photos/${photoId}/${imgName}${suffix}`;
  }

  // в”Җв”Җв”Җ жё…зҗҶ в”Җв”Җв”Җ

  /** йҮҠж”ҫиө„жәҗпјҲе…ій—ӯеҗҺеҸ°жҺўжҙ»е®ҡж—¶еҷЁпјү */
  destroy(): void {
    this.domainManager.shutdown();
  }
