  API_FAVORITE,
  API_FAVORITE_FOLDER,
  API_LOGIN,
  PAGE_SIZE_SEARCH,
  PAGE_SIZE_FAVORITE,
  IMAGE_SUFFIX_LIST,
  APP_HEADERS_IMAGE,
  APP_TOKEN_SECRET,
  APP_TOKEN_SECRET_2,
  DEFAULT_RETRY_TIMES,
} from '../common/Constants';
import {
  JmApiResponse,
